{
  "name": "semoi-obsidian",
  "version": "0.1.2",
  "description": "Obsidian plugin client for semoi.net — capture keystroke evidence and mint proof-of-writing certificates.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "semoi",
    "proof-of-writing"
  ],
  "author": "gjtorikian",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "6.38.6",
    "@types/node": "^25.8.0",
    "esbuild": "^0.28.0",
    "obsidian": "^1.12.3",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
